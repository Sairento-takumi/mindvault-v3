<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.yonghaekim.bge-m3-mlx</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Library/Frameworks/Python.framework/Versions/3.10/bin/python3</string>
        <string>/Users/yonghaekim/my-folder/apps/mindvault-v3/scripts/bge_m3_server.py</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/yonghaekim</string>
        <key>PATH</key>
        <string>/Library/Frameworks/Python.framework/Versions/3.10/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HF_HOME</key>
        <string>/Users/yonghaekim/.cache/huggingface</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/yonghaekim</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/Users/yonghaekim/Library/Logs/bge-m3-mlx.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/yonghaekim/Library/Logs/bge-m3-mlx.err</string>

    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>
